# =====================================================
# CampusLink — Variables d'environnement
# Copier ce fichier en ".env" et adapter les valeurs
# =====================================================

# ----- PostgreSQL -----
DB_NAME=campuslink_db
DB_USER=campuslink
DB_PASS=campuslink_pass

# ----- JWT -----
# IMPORTANT : changer en production (min 256 bits = 32 caractères)
JWT_SECRET=changeme_very_long_secret_key_must_be_at_least_256_bits_long

# ----- Spring Profile -----
SPRING_PROFILES_ACTIVE=prod

# ----- (optionnel) Firebase — si activé -----
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
